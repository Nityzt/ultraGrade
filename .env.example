GEMINI_API_KEY=your_gemini_api_key_here
PORT=3001
CLIENT_URL=http://localhost:5173
SUPABASE_URL=https://your-project.supabase.co

# Optional — server-side SERVICE ROLE key (Supabase → Settings → API).
# Enables the public ICS calendar feed (/api/calendar/:token.ics) and the
# immigration content cache. NEVER expose this to the browser. If unset, those
# two features return "not configured" and the rest of the app is unaffected.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — distributed rate limiting (Upstash Redis REST).
# If unset, the server falls back to an in-memory per-process limiter.
# Get free credentials at https://console.upstash.com (Redis → REST API).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Client-side (prefix with VITE_ so Vite exposes them to the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_API_URL=  # empty for local dev (Vite proxy handles /api); set to Render URL in production
